[
  {
    "name": "/latest shows latest resources",
    "steps": [
      {
        "send": { "text": "/latest" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Here are the latest resources:" } }
        ]
      }
    ]
  },
  {
    "name": "Latest menu button shows latest resources",
    "steps": [
      {
        "send": { "callback": "latest:show" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "Here are the latest resources:" } }
        ]
      }
    ]
  }
]
