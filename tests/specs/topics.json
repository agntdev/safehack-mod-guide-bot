[
  {
    "name": "/topics shows topic list",
    "steps": [
      {
        "send": { "text": "/topics" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Choose a topic to explore:" }
          }
        ]
      }
    ]
  },
  {
    "name": "Topics menu button shows topic list",
    "steps": [
